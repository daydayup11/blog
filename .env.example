# 复制此文件为 .env 并修改配置
# cp .env.example .env

# ── 必须修改 ──────────────────────────────────────────────────
# 后台登录密码（强烈建议修改）
ADMIN_PASS=your-strong-password-here

# JWT 签名密钥（随机字符串即可，如：openssl rand -hex 32）
JWT_SECRET=your-random-secret-here

# ── 可选修改 ──────────────────────────────────────────────────
# 后台用户名（默认 admin）
ADMIN_USER=admin

# 服务端口（默认 8080）
PORT=8080

# ── 一般不需要改 ──────────────────────────────────────────────
DB_PATH=/app/data/blog.db
FRONTEND_DIR=/app/frontend
